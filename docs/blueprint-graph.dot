strict digraph "" {	graph [bgcolor=transparent];	node [label="\N",		penwidth=1.8	];	edge [arrowhead=vee];	"def:local-witness"	[color=green,		fillcolor="#B0ECA3",		label="local-witness",		shape=box,		style=filled];	"def:initial-cover"	[color=green,		fillcolor="#B0ECA3",		label="initial-cover",		shape=box,		style=filled];	"def:local-witness" -> "def:initial-cover"	[style=dashed];	"thm:exists-refinement"	[color=green,		label="exists-refinement",		shape=ellipse];	"def:initial-cover" -> "thm:exists-refinement"	[style=dashed];	"thm:exists-sup-reduction"	[color=green,		label="exists-sup-reduction",		shape=ellipse];	"thm:exists-refinement" -> "thm:exists-sup-reduction"	[style=dashed];	"def:spaced"	[color=green,		fillcolor="#B0ECA3",		label=spaced,		shape=box,		style=filled];	"def:spaced" -> "def:initial-cover"	[style=dashed];	"def:cover"	[color=green,		fillcolor="#B0ECA3",		label=cover,		shape=box,		style=filled];	"def:cover" -> "thm:exists-refinement"	[style=dashed];	"thm:sup-reduction-of-cover"	[color=green,		label="sup-reduction-of-cover",		shape=ellipse];	"def:cover" -> "thm:sup-reduction-of-cover"	[style=dashed];	"thm:sup-reduction-of-cover" -> "thm:exists-sup-reduction"	[style=dashed];}
